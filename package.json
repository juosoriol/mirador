{
  "name": "mirador",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "demos": "vite --open /demos/index.html",
    "build": "vite build",
    "preview": "vite preview",
    "split:phase0": "node scripts/split-phase0.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:desktop": "playwright test --project=desktop",
    "test:mobile": "playwright test --project=mobile",
    "test:core": "playwright test tests/e2e/desktop/core.spec.js tests/e2e/mobile/core.spec.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:shared": "playwright test --project=shared",
    "setup:e2e": "node scripts/write-e2e.mjs",
    "test:all": "npm run setup:e2e && playwright test",
    "serve": "vite preview --port 8000"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-react": "^4.7.0",
    "dotenv": "^16.5.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
